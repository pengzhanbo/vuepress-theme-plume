exports[`codepenPlugin > should work 1`] = `"<VPCodePen title="Code Pen" tab="result" width="100%" height="400px" user="user" slash="slash" /><VPCodePen title="Code Pen" tab="result" width="100%" height="400px" user="user" slash="slash" preview /><VPCodePen title="codepen" tab="css,result" width="100%" height="400px" user="user" slash="slash" preview editable theme="dark" />"`;
